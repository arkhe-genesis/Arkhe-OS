{
  "name": "cathedral-consent-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "API de consentimento granular para a Catedral Arkhe",
  "author": "Cathedral Contributors",
  "license": "Apache-2.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec node --experimental-specifier-resolution=node src/server.js",
    "build": "node scripts/build.js",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .js --fix",
    "lint:strict": "eslint src --ext .js",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:integration": "NODE_ENV=test vitest run tests/integration",
    "audit": "npm audit --audit-level=moderate",
    "prepare": "cd .. && husky install backend/.husky"
  },
  "dependencies": {
    "cathedral-sdk": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
