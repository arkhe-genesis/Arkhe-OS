// crystal_control.plank
const CRYSTAL_NODE_ID: bytes32 = 0x7f3a9c2e;
const SLOT_PHASE: u256 = 0x10;
const SLOT_COHERENCE: u256 = 0x11;

fn init() {
    @evm_sstore(SLOT_PHASE, 1618033);
    @evm_sstore(SLOT_COHERENCE, 920);
}

fn send_phase_command(target_phase: u256) {
    let self_M = @evm_sload(SLOT_COHERENCE);
    @evm_emit_log(target_phase, self_M);
}
