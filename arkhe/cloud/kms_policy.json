{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ArkheKMSUsageP1",
      "Effect": "Allow",
      "Action": [
        "kms:GenerateDataKey",
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:DescribeKey"
      ],
      "Resource": "arn:aws:kms:us-east-1:123456789012:key/arkhe-master-key",
      "Condition": {
        "StringEquals": {
          "kms:EncryptionContext:arkhe:substrate": "243",
          "kms:EncryptionContext:arkhe:canon": "∞.Ω.∇+++.243.cloud_integration"
        }
      }
    }
  ]
}
