# ============================================================================
# ARKHE Ω‑TEMP — .gitmodules
# ============================================================================
# This file defines all submodules that constitute the ARKHE multiverse.
# Each substrate, binding, mock SDK, and tooling is an independent repository
# pinned to a specific commit. Recursive clone:
#   git clone --recurse-submodules https://github.com/arkhe-os/arkhe.git
# ============================================================================

# ── Low‑level firmware ───────────────────────────────────────────────────
[submodule "bootloader"]
	path = bootloader
	url = https://github.com/arkhe-os/bootloader.git
[submodule "kernel"]
	path = kernel
	url = https://github.com/arkhe-os/kernel.git

