# =============================================================================
# timing.xdc — Clock and path constraints for Arkhe Pulse Sequencer
# =============================================================================

# Primary 280 MHz differential system clock (from Zynq PS or external oscillator)
create_clock -name sys_clk_280 -period 3.571 [get_ports sys_clk_280_p]

# 14 GHz DAC sample clock — generated by external PLL/VCO, enters via GTX
create_clock -name dac_clk_14g -period 0.0714 [get_ports dac_clk_in_p]

# Asynchronous boundaries between sys_clk_280 and dac_clk_14g
set_clock_groups -asynchronous \
    -group [get_clocks sys_clk_280] \
    -group [get_clocks dac_clk_14g]

# AXI Stream interface (PS→PL) — constrained by M_AXI_GP0 clock (100 MHz typical)
create_clock -name axi_clk_100 -period 10.0 [get_ports m_axi_gp0_aclk]
set_clock_groups -asynchronous \
    -group [get_clocks sys_clk_280] \
    -group [get_clocks axi_clk_100]

# Crosstalk BRAM lookup — false path to combinatorial read
set_false_path -from [get_cells -hier -filter {NAME =~ *crosstalk_matrix*}] \
               -to [get_cells -hier -filter {NAME =~ *checker*/*}]

# Pulse waveform memory (BRAM) — relaxed timing for large dual‑port access
set_multicycle_path 2 -setup -from [get_cells -hier -filter {NAME =~ *pulse_waveform_ram*}] \
                             -to [get_cells -hier -filter {NAME =~ *generator*/*}]