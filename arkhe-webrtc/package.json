{
  "name": "arkhe-webrtc",
  "version": "4.3.9",
  "description": "ARKHE Ω-TEMP — Decentralized Temporal Consensus (WebRTC Mesh)",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "test": "jest --coverage",
    "test:integration": "jest --testPathPattern='test/integration' --runInBand",
    "signaling": "ts-node server/signaling/index.ts",
    "start": "concurrently \"npm:signaling\" \"npm:dev\"",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bigint-crypto-utils": "^3.3.0",
    "crypto-browserify": "^3.12.0",
    "simple-peer": "^9.11.1",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.3.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/simple-peer": "^9.11.9",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
