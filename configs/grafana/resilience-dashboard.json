{
  "dashboard": {
    "uid": "cathedral-resilience-vitral",
    "title": "Vitral da Alma — Resiliência da Catedral Arkhe",
    "tags": ["caos", "resiliência", "arkhe", "playbook"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "templating": {
      "list": [
        {
          "name": "region",
          "type": "datasource",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "query": "label_values(cathedral_subsystem_health, region)",
          "multi": true,
          "includeAll": true,
          "allValue": ".*",
          "current": { "selected": true, "text": "All", "value": "$__all" }
        },
        {
          "name": "layer",
          "type": "custom",
          "query": "hardware, network, consensus, application",
          "multi": true,
          "includeAll": true,
          "current": { "selected": true, "text": "All", "value": "$__all" }
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Ω-Score Global (SANGUE)",
        "type": "gauge",
        "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
        "targets": [
          { "expr": "cathedral_organism_vitality", "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "green", "value": 0.9 }
              ]
            },
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "id": 2,
        "title": "Ω-Score por Subsistema",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 0, "w": 16, "h": 8 },
        "targets": [
          { "expr": "cathedral_subsystem_health{region=~\"$region\"}", "legendFormat": "{{system}}", "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "id": 3,
        "title": "Latência p99 por Região (FLEUMA)",
        "type": "heatmap",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [
          { "expr": "sum(rate(cathedral_query_latency_ms_bucket{region=~\"$region\"}[5m])) by (le, region)", "format": "heatmap", "refId": "A" }
        ]
      },
      {
        "id": 4,
        "title": "Injeções Ativas (BÍLIS NEGRA)",
        "type": "table",
        "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
        "targets": [
          { "expr": "chaos_experiment_active{region=~\"$region\"}", "format": "table", "refId": "A" }
        ]
      }
    ]
  }
}
