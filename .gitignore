.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# ============================================================
# 🌐 NETWORK / FEDERATION / DHT (local state)
# ============================================================
# DHT cache local
.dht-cache/
.peers.json
.federation-state/

# Gossip buffers
.gossip-buffer/
*.gossip.log

# ============================================================
# 🧠 AGI / MODEL / TRAINING (large/generated)
# ============================================================
# Model checkpoints (grandes, versionados via registry)
models/checkpoints/*.pt
models/checkpoints/*.bin
models/checkpoints/*.safetensors
*.ckpt
*.pth
*.onnx
*.tflite

# Training artifacts
runs/
tensorboard/
wandb/
mlruns/

# Generated graphs/visualizations
viz/
plots/
*.png
*.svg
*.pdf
!docs/*.pdf

# ============================================================
# 📚 DOCUMENTAÇÃO GERADA
# ============================================================
docs/_build/
docs/build/
site/
public/
*.html
!README.md
!DEPLOY.md
!SECURITY.md

# ============================================================
# 🔄 CI/CD / PIPELINE (local overrides)
# ============================================================
.github/workflows/local-*.yml
.gitlab-ci-local/
.circleci/local-config.yml

# ============================================================
# 🧩 SUBSTRATE-SPECIFIC EXCLUSIONS
# ============================================================
# Substrate 315-317: RCP/Omni runtime state
**/runtime/quantum/*.trace
**/runtime/quantum/*.dump

# Substrate 320: AGI.onion local state
**/onion/*.pid
**/onion/control_port

# Substrate 321: Federation local cache
**/federate/.peers
**/federate/.routing-table

# Substrate 322-323: Learning state
**/learning/.replay-buffer
**/learning/.optimizer-state

# Substrate 324: PyInstaller build artifacts
dist/arkhe-agi
dist/arkhe-agi.exe
build/pyinstaller/

# Substrate 325: Integrity monitor state
**/integrity/.fingerprints
**/integrity/.audit-log.tmp

# Substrate 326: Operational dashboards
**/observability/.prometheus-data
**/observability/.grafana-temp

# ============================================================
# 🚫 EXPLICITLY ALLOWED (overrides)
# ============================================================
# Manter configs de exemplo
!config/*.example
!config/*.sample
!config/*.template

# Manter scripts de build/deploy
!scripts/*.sh
!scripts/*.py
!deploy/*.yaml
!deploy/*.yml

# Manter documentação canônica
!*.md
!docs/**/*.md
!SUBSTRATES.md
!ARCHITECTURE.md

# Manter arquivos de definição de projeto
!pyproject.toml
!setup.py
!requirements*.txt
!Makefile
!Containerfile
!Dockerfile*
!podman*.yaml
!k8s*.yaml
!*.spec

# ============================================================
# 🏁 FINAL RULES
# ============================================================
# Ignorar tudo que não foi explicitamente permitido em pastas sensíveis
**/secrets/**
**/credentials/**
**/private/**

# Última linha: ignorar arquivos temporários genéricos
*.tmp.*
*.temp.*
*.backup
*.bak
app_arkhe/frontend/node_modules
final_app_arkhe/frontend/node_modules
arkhe-os/ui/desktop/node_modules
