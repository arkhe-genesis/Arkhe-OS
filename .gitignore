*.test-result
junit.xml
pytest.xml
coverage/
*.prof
*.pstats
*.trace

# Mock data gerado
tests/fixtures/generated/
tests/mocks/auto-generated/

# ============================================================
# 📦 DISTRIBUIÇÃO / PACOTES / RELEASES
# ============================================================
# Pacotes construídos (assinados separadamente)
dist/*.deb
dist/*.rpm
dist/*.tar.gz
dist/*.zip
dist/SHA256SUMS
dist/SHA256SUMS.asc
dist/DEPLOYMENT_REPORT.md

# Release artifacts locais
releases/
artifacts/
publish/

