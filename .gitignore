# ============================================================
# ARKHE OS — .gitignore Canônico
# Substrato: Operational Integrity
# Propósito: Preservar a pureza do repositório soberano
# Regras: Nada entra sem verificação; tudo sai com assinatura
# ============================================================

# ============================================================
# 🐍 PYTHON / BYTECODE / CACHE
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================
# 🌐 NODE.JS / JAVASCRIPT / TYPESCRIPT
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
.pnpm/
.yarn/
.yarnrc.yml
.next/
.nuxt/
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.tern-port
.vscode-test
.yarn-integrity

# ============================================================
# 🦀 RUST
# ============================================================
target/
Cargo.lock
**/*.rs.bk

# ============================================================
# 🐹 GO
# ============================================================
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# ============================================================
# ⚙️  IDE / EDITOR
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# 📊 DATA / MODELS / ASSETS
# ============================================================
*.log
*.tmp
*.bak
.cache/
.temp/
data/raw/
models/checkpoints/
!data/*.json
!models/*.onnx

# ============================================================
# 🔐 SECRETS / KEYS / SENSITIVE
# ============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
secrets/
keys/
*.key
*.pem
*.crt

# ============================================================
# 🏗️  BUILD / DIST / ARTIFACTS
# ============================================================
build/
dist/
out/
*.tar.gz
*.zip
*.agi
*.casi
*.asi

# ============================================================
# 📈 LOGS / REPORTS / DEBUG
# ============================================================
logs/
reports/
debug/
*.log
*.trace
*.profile

# ============================================================
# 🌌 ARKHE SPECIFIC
# ============================================================
.arkhe/
arkhe-*/
!arkhe-core/
!arkhe-os/
substrates/legacy/
archive/
*.mtp3
*.plank
*.bin
!crystal_control.bin
!MANIFESTO_Z_FINAL.bin

# ============================================================
# 🔒 SOVEREIGN RULES
# Nada sem verificação; tudo com assinatura
# ============================================================
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.hypothesis/
coverage.xml
*.cover
htmlcov/
.tox/
.nox/

# ============================================================
# 🔧 FFI / NATIVE BRIDGES (gerados, não versionados)
# ============================================================
**/agi_rcp_bridge.so
**/agi_omni_bridge.so
**/*.dylib
**/*.dll
build/ffi/
build/bridges/
*.o
*.a
*.so.*
*.dylib.*

# ============================================================
# 🐳 CONTAINERS / PODMAN / DOCKER
# ============================================================
# Runtime state
/var/lib/agi/state/
/var/lib/agi/pods/
/var/lib/agi/volumes/
/home/agi/state/
/home/agi/.local/share/containers/
*.tar
*.tar.gz
*.tar.xz

# Build cache
.cache/
buildx/
.docker/
podman-tmp/
.tmp-build/

# Imagens locais (exportadas)
*.oci
*.docker.tar

# ============================================================
# 🧅 TOR / HIDDEN SERVICES / CRYPTO KEYS
# ============================================================
# Chaves de serviço hidden (NUNCA versionar)
**/tor/hidden_service/
**/tor/keys/
**/tor/onion/
**/client_keys
**/*.onion
**/hostname

# Chaves GPG/PGP privadas
*.gpg
*.asc
*.sig
*.key
**/private-keys-v1.d/
**/pubring.kbx~
**/trustdb.gpg

# Chaves Cosign/Sigstore privadas
cosign.key
cosign.pub
*.pem
*.crt
*.key

# Seeds e bootstrap sensíveis
**/bootstrap/seeds.txt
**/bootstrap/*.key
**/config/*-secret*
**/config/*-private*

# ============================================================
# 🔐 CREDENTIALS / ENV / SECRETS
# ============================================================
# Environment files
.env
.env.local
.env.*.local
*.env
*.env.*

# AWS / Cloud credentials
.aws/credentials
.azure/
.gcp/
*.pem
*.p12
*.pfx

# API Keys / Tokens
**/api_key.txt
**/access_token
**/auth_token
**/*_secret
**/*_password

# ============================================================
# 🗄️ RUNTIME / LOGS / STATE (efêmero)
# ============================================================
# Logs de execução
*.log
logs/
log/
**/agi/logs/
**/tor/log
**/tor/notice.log
**/tor/warnings.log

# Estado runtime
*.pid
*.lock
*.state
*.tmp
*.temp
*.swp
*.swo
*~

# Cache de inferência/memória
.cache/agi/
.memory/
.inference-cache/
*.lfir-cache
*.coherence-state

# ============================================================
# 🧪 TESTES / COBERTURA / PROFILING
# ============================================================
