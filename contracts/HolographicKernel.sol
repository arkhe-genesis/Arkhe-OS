pragma solidity ^0.8.30;

interface ICrystalCodex {
    struct SwapReceipt {
        uint256 volume;
        uint256 price;
        uint256 timestamp;
    }
    function getSwapReceipts(bytes32 poolDid, uint256 windowStart, uint256 windowEnd) external view returns (SwapReceipt[] memory);
}

interface IZK_PriceVerifier {
    function generateTWAPProof(bytes32 poolDid, uint256 price, uint256 windowStart, uint256 windowEnd) external view returns (bytes memory);
}

/**
 * @title HolographicPriceKernel (FS-117v2)
 * @notice TWAP oracle replacement using aggregated, ZK-verifiable price data from the Codex.
 */
contract HolographicPriceKernel {
    ICrystalCodex public codex;
    IZK_PriceVerifier public zkVerifier;

    constructor(address _codex, address _zkVerifier) {
        codex = ICrystalCodex(_codex);
        zkVerifier = IZK_PriceVerifier(_zkVerifier);
    }

    /**
     * @notice Computes a volume-weighted average price over a window.
     */
    function getHolographicTWAP(
        bytes32 poolDid,
        uint256 windowStart,
        uint256 windowEnd
    ) external view returns (uint256 price, bytes memory zkProof) {
        ICrystalCodex.SwapReceipt[] memory receipts = codex.getSwapReceipts(poolDid, windowStart, windowEnd);

        uint256 totalVolume = 0;
        uint256 weightedSum = 0;

        for (uint i = 0; i < receipts.length; i++) {
            totalVolume += receipts[i].volume;
            weightedSum += receipts[i].price * receipts[i].volume;
        }

        require(totalVolume > 0, "No receipts in window");
        price = weightedSum / totalVolume;

        // In a real implementation, the proof is generated by the Codex or a prover.
        zkProof = zkVerifier.generateTWAPProof(poolDid, price, windowStart, windowEnd);

        return (price, zkProof);
    }
}
