{
  "name": "arkhe-chain-node",
  "version": "1.0.0",
  "private": true,
  "description": "The Arkhe-Chain Complete Ecosystem",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "dev": "npm run dev --workspaces",
    "arkhe:up": "docker-compose up -d --build",
    "arkhe:down": "docker-compose down",
    "arkhe:logs": "docker-compose logs -f",
    "arkhe:stress": "docker exec -it cuda-reconciler python src/cuda/stress_test_144k.py",
    "arkhe:report": "docker exec -it node-backend python3 scripts/generate_report.py"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2"
  }
}
