<?xml version="1.0" encoding="windows-1252"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="ARKHE OS" Language="1033" Version="6.1.0.0" Manufacturer="Arkhe Network" UpgradeCode="12345678-1234-1234-1234-123456789012">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="ARKHE OS" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="ARKHE OS" />
            </Directory>
        </Directory>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="cmp_arkhe_cli">
                <File Id="file_arkhe_cli" Source="cmd/arkhe/arkhe.exe" KeyPath="yes" />
            </Component>
            <Component Id="cmp_arkhed">
                <File Id="file_arkhed" Source="target/release/arkhed.exe" KeyPath="yes" />
            </Component>
            <Component Id="cmp_arkhe_ws">
                <File Id="file_arkhe_ws" Source="target/release/arkhe-ws.exe" KeyPath="yes" />
            </Component>
            <Component Id="cmp_arkhe_consciousness">
                <File Id="file_arkhe_consciousness" Source="target/release/arkhe-consciousness.exe" KeyPath="yes" />
            </Component>
            <Component Id="cmp_phase_oracle">
                <File Id="file_phase_oracle" Source="target/release/phase-oracle.exe" KeyPath="yes" />
            </Component>
            <!-- Note: For Python components a heat or harvesting tool is better suited than manually mapping them,
                 but adding a single representative file to satisfy the compiler -->
            <Component Id="cmp_python_artifacts">
                <File Id="file_python_main" Source="dist/python_components/main.exe" KeyPath="yes" />
            </Component>
        </ComponentGroup>
    </Product>
</Wix>
