    {"node_a": "BETA-02", "node_b": "GAMMA-03", "auto_accept": true}
  ],
  "temporal": {
    "window_seconds": 157788000,
    "ledger_ttl": "infinite",
    "consistency_model": "novikov"
  },
  "ai_router": {
    "enabled_on": ["BETA-02"],
    "endpoint": "http://localhost:11434",
    "model": "llama3.1:8b",
    "temperature": 0.3,
    "max_tokens": 512,
    "features": {
      "routing": true,
      "paradox_detection": true,
      "content_filter": true,
      "chain_optimization": true
    },
    "fallback": "heuristic"
  },
  "ds4": {
    "sensors": ["accel", "gyro", "light", "touch"],
    "publish_interval_ms": 100,
    "buffer_size": 1000
  },
  "chat_demo": {
    "scenario": "three_hop_retrocausal",
    "message_flow": "ALFA → BETA(AI) → GAMMA",
    "time_travel": "+120s",
    "verify_consistency": true,
    "log_level": "INFO"
  }
}