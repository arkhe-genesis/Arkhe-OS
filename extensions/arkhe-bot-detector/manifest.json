{
  "manifest_version": 3,
  "name": "Arkhe Bot Detector — Human Coherence Proof",
  "version": "68.3.0",
  "description": "Prova criptográfica de humanidade baseada em telemetria comportamental e modos de Fibonacci. Zero-knowledge: seus dados nunca saem do seu browser.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms"
  ],

  "host_permissions": [
    "https://*.arkhe.network/*",
    "https://sepolia.infura.io/*"
  ],

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/telemetry_collector.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup/index.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["wasm/*.wasm", "wasm/*.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
