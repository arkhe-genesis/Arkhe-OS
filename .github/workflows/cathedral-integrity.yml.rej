--- cathedral-integrity.yml
+++ cathedral-integrity.yml
@@ -25,9 +25,6 @@
           - .github/workflows/cathedral-integrity.yml

 env:
-  # Bypass Node.js 20 deprecation warning
-  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
-
   # Configurações do Arkhe OS
   CATHEDRAL_VERSION: "v∞.Ω.∇+++.SINGULARITY.EVO"
   MIN_PHI_C_THRESHOLD: "0.99"
@@ -52,19 +49,19 @@

     steps:
       - name: 📥 Checkout code
-        uses: actions/checkout@v4
+        uses: actions/checkout@v4.2.2

       - name: 🛠️ Setup MSVC environment
         uses: ilammy/msvc-dev-cmd@v1

       - name: 🔐 Generate Mock Test Certificate
         run: |
           echo "Generating test certificate for Cathedral Driver..."
           # Em produção, usa-se hardware HSM via SignTool
           # Aqui simulamos a criação do certificado para testes

       - name: 🔨 Build Cathedral Driver (x64 Release)
         run: |
           echo "Building Cathedral Driver..."
           mkdir -p catedral/x64/Release/
           echo "MOCK DRIVER BINARY" > catedral/x64/Release/catedral.sys
--- /dev/null
+++ /dev/null
@@ -102,7 +99,7 @@

     steps:
       - name: 📥 Checkout code
-        uses: actions/checkout@v4
+        uses: actions/checkout@v4.2.2

       - name: 📦 Download build artifacts
-        uses: actions/download-artifact@v4
+        uses: actions/download-artifact@v4.1.8
