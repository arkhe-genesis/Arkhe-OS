{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XtraMCP Protocol Schema — Substrate 630 Extension",
  "description": "Model Context Protocol variant for academic writing (PaperDebugger)",
  "type": "object",
  "required": ["protocol_version", "tools", "agents"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "enum": ["xtramcp-1.0"]
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "input_schema", "output_schema"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "input_schema": { "type": "object" },
          "output_schema": { "type": "object" },
          "latency_class": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "capabilities"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["prompt_template", "workflow_based"]
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "model": { "type": "string" },
          "temperature": { "type": "number", "minimum": 0, "maximum": 2 }
        }
      }
    }
  }
}
