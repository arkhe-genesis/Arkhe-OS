<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="ARKHE OS Windows Port" Language="1033" Version="2.3.0.0" Manufacturer="Arkhe Project" UpgradeCode="7E5528DB-235E-4B07-A9D4-09FE9199A6E1">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of ARKHE OS is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="ARKHE OS Constitutional Runtime" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentGroupRef Id="ServiceComponents" />
        </Feature>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="Arkhe">
                    <Directory Id="LOGSFOLDER" Name="Logs" />
                    <Directory Id="PROOFSFOLDER" Name="Proofs" />
                    <Directory Id="SUBSTRATOSFOLDER" Name="Substratos" />
                </Directory>
            </Directory>
        </Directory>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <!-- Ensure root directories and permissions exist -->
            <Component Id="CreateLogsFolder" Guid="*">
                <CreateFolder Directory="LOGSFOLDER">
                    <Permission User="Users" GenericAll="yes" />
                </CreateFolder>
            </Component>
            <Component Id="CreateProofsFolder" Guid="*">
                <CreateFolder Directory="PROOFSFOLDER">
                    <Permission User="Users" GenericAll="yes" />
                </CreateFolder>
            </Component>
        </ComponentGroup>

        <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">
            <Component Id="ArkheNativeService" Guid="*">
                <File Id="ArkheServiceExe" Source="ArkheService.exe" KeyPath="yes" />
                <ServiceInstall
                    Id="ServiceInstaller"
                    Type="ownProcess"
                    Name="ArkheBridge"
                    DisplayName="ARKHE OS Constitutional Bridge"
                    Description="Native C#/.NET Runtime for ARKHE OS V2.3"
                    Start="auto"
                    Account="LocalSystem"
                    ErrorControl="normal" />
                <ServiceControl
                    Id="StartService"
                    Start="install"
                    Stop="both"
                    Remove="uninstall"
                    Name="ArkheBridge"
                    Wait="yes" />
            </Component>
        </ComponentGroup>
    </Product>
</Wix>
